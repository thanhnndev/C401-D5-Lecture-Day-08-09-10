# Mock SSE (default): bỏ qua hoặc đặt true
# AGENT_USE_MOCK=true

# Làm chậm thêm các khoảng nghỉ giữa sự kiện mock (1 = mặc định, 2 = gấp đôi thời gian chờ)
# MOCK_SSE_MULTIPLIER=1

# Khi có FastAPI + LangGraph trong repo — tắt mock và trỏ base URL
# AGENT_USE_MOCK=false
# LANGGRAPH_HTTP_URL=http://127.0.0.1:8080
# Tùy chọn path (mặc định /runs/stream)
# LANGGRAPH_CHAT_PATH=/runs/stream
