# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Chọn "openai" hoặc "gemini"
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Base URL API (OpenAI-compatible). Để trống = endpoint mặc định OpenAI (https://api.openai.com/v1).
# Ví dụ Ollama local: OPENAI_BASE_URL=http://127.0.0.1:11434/v1/
# OPENAI_BASE_URL=

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=...

# Model mặc định
LLM_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# === Embedding ===
# Chọn "openai" (OpenAI-compatible: OpenAI cloud hoặc Ollama qua OPENAI_BASE_URL) hoặc "jina"
EMBEDDING_PROVIDER=openai

# Model embedding (OpenAI: text-embedding-3-small; Ollama: tên model đã pull, vd. nomic-embed-text-v2-moe)
# EMBEDDING_MODEL=text-embedding-3-small

# Jina (chỉ khi EMBEDDING_PROVIDER=jina)
# AUTHORIZATION_JINA=jina_...

# Model sentence-transformers nếu dùng local embedding (chưa wire trong index)
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
