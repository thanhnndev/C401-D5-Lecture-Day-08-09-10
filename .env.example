# Day 08 Lab — RAG Pipeline — copy thành .env

# === LLM Provider ===

# OpenAI-compatible API key (OpenAI cloud: sk-... ; Ollama: thường đặt ollama)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Hai base URL độc lập (OpenAI-compatible /v1). Để trống = https://api.openai.com/v1
CHAT_BASE_URL=
EMBEDDING_BASE_URL=

# Model chat (OpenAI: gpt-4o-mini ; Ollama: tên model đã pull)
CHAT_MODEL=gpt-4o-mini

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Rerank — OpenAI-compatible POST {RERANK_BASE_URL}/rerank (LM Studio :1234, Ollama, …)
# RERANK_BASE_URL=http://127.0.0.1:1234/v1
# RERANKING_MODEL=qwen3-reranker-0.6b
# RERANK_API_KEY=lm-studio
# Hoặc Jina (để trống RERANK_BASE_URL): JINA_API=jina_...

# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# EMBEDDING_PROVIDER=jina → cần AUTHORIZATION_JINA=jina_...
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
