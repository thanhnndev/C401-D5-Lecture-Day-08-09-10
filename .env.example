# Day 08 Lab — RAG Pipeline — copy thành .env

LLM_PROVIDER=openai

# OpenAI-compatible API key (OpenAI cloud: sk-... ; Ollama: thường đặt ollama)
OPENAI_API_KEY=sk-...

# Hai base URL độc lập (OpenAI-compatible /v1). Để trống = https://api.openai.com/v1
CHAT_BASE_URL=
EMBEDDING_BASE_URL=https://pro-chicken-luckily.ngrok-free.app/v1/

# Model chat (OpenAI: gpt-4o-mini ; Ollama: tên model đã pull)
CHAT_MODEL=gpt-4o-mini

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=nomic-embed-text-v2-moe

# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# EMBEDDING_PROVIDER=jina → cần AUTHORIZATION_JINA=jina_...
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
